# Project wide .gitignore
*.iml
.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties

# Kotlin / Compose specific
.kotlin/
*.main.kts

# Android Studio / IntelliJ
*.iws
*.ipr
out/

# App module specific (fallback if not in app/.gitignore)
app/build/
app/*.iml

# Signing files (Keep your keystore private!)
*.jks
*.keystore
*.p12

# Credentials & Secrets
secrets.properties
google-services.json

# Temporary / OS files
Thumbnails.db
ehthumbs.db
Desktop.ini
